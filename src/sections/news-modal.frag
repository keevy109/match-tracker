<div id="newsModal" class="news-modal" aria-hidden="true">
  <div class="news-modal-overlay" id="newsModalOverlay"></div>
  <div class="news-modal-card" role="dialog" aria-modal="true">
    <button class="news-modal-close" id="newsModalClose" aria-label="Schließen">✕</button>
    <div class="news-modal-image" id="nmImage"><span id="nmIcon"></span></div>
    <div class="news-modal-body">
      <div class="news-modal-date" id="nmDate"></div>
      <h2 class="news-modal-title" id="nmTitle"></h2>
      <div class="news-modal-text" id="nmText"></div>
    </div>
  </div>
</div>
